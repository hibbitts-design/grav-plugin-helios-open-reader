{# Plugin override of Helios prev-next.html.twig
   On section-page templates: suppresses bottom nav when hor_prev_next_position is 'top'.
   On all other templates: always renders the nav (position setting is section-page-only).
   Suppressed entirely when embedded (?embedded=true or ?chromeless=true). #}
{% if not chromeless and (hor_prev_next_position|default('both') in ['bottom', 'both'] or page.template != 'section-page') %}
{% set prev = helios_prev|default(null) %}
{% set next = helios_next|default(null) %}

{% if section_progress_current is defined %}
<div class="hor-progress">
    <div class="hor-progress-bar"
         role="progressbar"
         aria-label="Reading progress"
         aria-valuenow="{{ section_progress_current }}"
         aria-valuemin="0"
         aria-valuemax="{{ section_progress_total }}"
         aria-valuetext="Page {{ section_progress_current }} of {{ section_progress_total }}">
        <div class="hor-progress-fill" aria-hidden="true" style="width: {{ ((section_progress_current / section_progress_total) * 100)|round }}%"></div>
    </div>
    <p class="hor-progress-text" aria-hidden="true">Page {{ section_progress_current }} of {{ section_progress_total }}</p>
</div>
{% endif %}

{% if prev or next %}
<nav class="prev-next-nav" aria-label="Page navigation">
    {% if prev %}
    <a href="{{ prev.url }}" class="nav-button prev group">
        <svg class="w-5 h-5 text-gray-400 group-hover:text-primary transition-colors" aria-hidden="true" focusable="false" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        <div>
            <span class="label">{{ 'THEME_HELIOS.PREVIOUS'|t }}</span>
            <span class="title block">{{ prev.title }}</span>
        </div>
    </a>
    {% else %}
    <div></div>
    {% endif %}

    {% if next %}
    <a href="{{ next.url }}" class="nav-button next group">
        <div>
            <span class="label">{{ 'THEME_HELIOS.NEXT'|t }}</span>
            <span class="title block">{{ next.title }}</span>
        </div>
        <svg class="w-5 h-5 text-gray-400 group-hover:text-primary transition-colors" aria-hidden="true" focusable="false" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
    </a>
    {% endif %}
</nav>
{% endif %}
{% endif %}
