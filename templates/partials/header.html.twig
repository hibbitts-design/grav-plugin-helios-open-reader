
{#
 # Plugin override of partials/header.html.twig (helios theme)
 # Changes from theme original:
 #   1. Git header link URL and icon use github_server to support both GitHub and Codeberg (search: PLUGIN CHANGE 1)
 #}
{% set theme_config = config.themes.helios %}
{% set appearance = theme_config.appearance %}
{% set logo = theme_config.logo %}

<header id="site-header" class="sticky top-0 z-20 flex items-center h-16 px-4 sm:px-6 lg:px-8 bg-white/50 dark:bg-gray-900/50 backdrop-blur border-b border-gray-200 dark:border-gray-800">

    {# Mobile menu button #}
    <button @click="mobileNavOpen = !mobileNavOpen"
            class="lg:hidden -ml-2 mr-2 p-2 rounded-lg text-gray-500 hover:bg-gray-100 dark:hover:bg-gray-800"
            aria-label="Toggle navigation">
        <svg x-show="!mobileNavOpen" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
        <svg x-show="mobileNavOpen" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" x-cloak>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
    </button>

    {# Breadcrumbs (mobile) - show on smaller screens #}
    <div class="lg:hidden flex-1 min-w-0">
        {% if helios_breadcrumbs is defined and helios_breadcrumbs|length > 0 %}
            <span class="text-sm font-medium text-gray-900 dark:text-white truncate">
                {{ helios_breadcrumbs|last.title }}
            </span>
        {% endif %}
    </div>

    {# Page title area (desktop) - version badge on left #}
    <div class="hidden lg:flex lg:items-center flex-1">
        {# Version badge #}
        {% if theme_config.versioning.enabled and theme_config.versioning.show_badge and helios_version %}
            {% set version_data = helios_version_info.versions|filter(v => v.is_current)|first %}
            <span class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-xs font-medium
                         {{ version_data.is_default ? 'bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400' : 'bg-primary/10 text-primary' }}">
                {{ version_data.label ?: helios_version }}
                {% if version_data.is_default %}
                    <span class="hidden sm:inline">- {{ 'THEME_HELIOS.VERSION_LATEST'|t }}</span>
                {% endif %}
            </span>
        {% endif %}
    </div>

    {# Header menu (right-aligned) #}
    {% if theme_config.header.menu %}
    <nav class="hidden lg:flex items-center gap-1 mr-4">
        {% for item in theme_config.header.menu %}
        <a href="{{ item.external ? item.route : url(item.route) }}"
           class="px-3 py-1.5 text-sm text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
           {{ item.external ? 'target="_blank" rel="noopener noreferrer"' : '' }}>
            {{ item.label }}
            {% if item.external %}
            <svg class="inline-block w-3 h-3 ml-1 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
            </svg>
            {% endif %}
        </a>
        {% endfor %}
    </nav>
    {% endif %}

    {# Right side actions #}
    <div class="flex items-center gap-2 sm:gap-4">

        {# Language switcher #}
        {% include 'partials/langswitcher.html.twig' %}

        {# Search trigger #}
        {% if theme_config.search.enabled %}
        <button @click="searchOpen = true" data-ys-open
                class="search-trigger"
                aria-label="Search documentation">
            <svg class="search-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
            </svg>
            <span class="search-placeholder">{{ 'THEME_HELIOS.SEARCH'|t }}</span>
            {% if theme_config.search.keyboard_shortcut %}
            {% set shortcut_key = theme_config.search.shortcut_key|default('k') %}
            <span class="search-kbd">
                <kbd class="hidden sm:inline">{{ browser.platform == 'macintosh' ? '⌘' : 'Ctrl' }}</kbd>
                <kbd>{{ shortcut_key|upper }}</kbd>
            </span>
            {% endif %}
        </button>
        {% endif %}

        {# Git repository link #}{# PLUGIN CHANGE 1 #}
        {% if theme_config.github.enabled and theme_config.github.repo and show_github_header_icon != false %}
        {% set git_icon = (github_server == 'github.com') ? 'tabler/brand-github.svg' : 'tabler/brand-git.svg' %}
        {% set git_label = (github_server == 'github.com') ? 'View on GitHub' : 'View on Codeberg' %}
        <a href="https://{{ github_server }}/{{ theme_config.github.repo }}"
           target="_blank"
           rel="noopener noreferrer"
           class="p-2 rounded-lg flex items-center text-gray-500 hover:text-gray-900 dark:hover:text-white hover:bg-gray-100 dark:hover:bg-gray-800"
           aria-label="{{ git_label }}">
            <span class="w-5 h-5 flex items-center justify-center">{{ svg_icon(git_icon)|raw }}</span>
        </a>
        {% endif %}

        {# Theme toggle - iOS style 3-way switch #}
        {% if appearance.selector %}
        {# Add x-cloak to the toggle wrapper so it stays hidden until Alpine finishes initializing #}
        <div class="theme-toggle" x-cloak role="radiogroup" aria-label="Theme selection">
            {# Sliding indicator - w-7 = 28px per button #}
            <div class="theme-toggle-indicator"
                 :class="{
                     'translate-x-0': theme === 'light',
                     'translate-x-7': theme === 'system',
                     'translate-x-14': theme === 'dark'
                 }"></div>

            {# Light mode button #}
            <button @click="theme = 'light'; localStorage.setItem('helios-theme', 'light'); document.documentElement.classList.remove('dark');"
                    class="theme-toggle-btn"
                    :class="{ 'theme-toggle-btn-active': theme === 'light' }"
                    role="radio"
                    :aria-checked="theme === 'light'"
                    aria-label="Light mode">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/>
                </svg>
            </button>

            {# System mode button #}
            <button @click="theme = 'system'; localStorage.setItem('helios-theme', 'system'); window.matchMedia('(prefers-color-scheme: dark)').matches ? document.documentElement.classList.add('dark') : document.documentElement.classList.remove('dark');"
                    class="theme-toggle-btn"
                    :class="{ 'theme-toggle-btn-active': theme === 'system' }"
                    role="radio"
                    :aria-checked="theme === 'system'"
                    aria-label="System theme">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
            </button>

            {# Dark mode button #}
            <button @click="theme = 'dark'; localStorage.setItem('helios-theme', 'dark'); document.documentElement.classList.add('dark');"
                    class="theme-toggle-btn"
                    :class="{ 'theme-toggle-btn-active': theme === 'dark' }"
                    role="radio"
                    :aria-checked="theme === 'dark'"
                    aria-label="Dark mode">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
                </svg>
            </button>
        </div>
        {% endif %}
    </div>
</header>
