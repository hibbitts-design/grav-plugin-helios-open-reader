{% extends helios_base_simple %}

{% block content %}
    {# Reader home header — title, subtitle, authors, edition, cover image, license badge #}
    <header class="mb-8 pb-8 border-b border-gray-200 dark:border-gray-800">
        <div class="flex flex-col {{ page.header.cover_image ? 'sm:flex-row sm:gap-8' : '' }}">

            {# Cover image — shown side-by-side on wider screens when set #}
            {% if page.header.cover_image %}
                {% set cover = page.media[page.header.cover_image] %}
                {% if cover %}
                <div class="flex-shrink-0 mb-6 sm:mb-0">
                    <img src="{{ cover.url }}" alt="{{ page.title }} cover" class="w-32 sm:w-40 rounded-lg shadow-md border border-gray-200 dark:border-gray-700">
                </div>
                {% endif %}
            {% endif %}

            <div class="flex-1">
                <h1 class="text-3xl sm:text-4xl font-bold tracking-tight text-gray-900 dark:text-white">
                    {{ page.title }}
                </h1>
                {% if page.header.subtitle %}
                <p class="mt-2 text-xl text-gray-500 dark:text-gray-400 italic">
                    {{ page.header.subtitle }}
                </p>
                {% endif %}
                {% if page.header.authors %}
                <p class="mt-3 text-base text-gray-600 dark:text-gray-400">
                    {{ page.header.authors }}
                </p>
                {% endif %}
                {% if page.header.edition %}
                <p class="mt-1 text-sm text-gray-500 dark:text-gray-500">
                    {{ page.header.edition }}
                </p>
                {% endif %}
                {% if page.header.license %}
                <p class="mt-3">
                    <span class="doc-badge doc-badge--plain text-xs">{{ page.header.license }}</span>
                </p>
                {% endif %}
            </div>
        </div>
    </header>

    {# Split page content above/below section cards using === delimiter #}
    {% set raw = page.rawMarkdown() %}
    {% if '===' in raw %}
        {% set content_above = page.summary() %}
        {% set full = page.content %}
        {% set content_below = (full starts with content_above) ? (full|slice(content_above|length))|trim : null %}
    {% else %}
        {% set content_above = page.content %}
        {% set content_below = null %}
    {% endif %}

    {# Page content above section cards #}
    {% if content_above|trim %}
        <article class="prose prose-lg dark:prose-invert max-w-none mb-8">
            {{ content_above|raw }}
        </article>
    {% endif %}

    {# Resume Reading strip — populated by helios.js from localStorage if a section page was previously visited #}
    <div id="hor-resume-reading" class="hor-resume-strip" hidden>
        <svg class="hor-resume-icon" aria-hidden="true" focusable="false" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17.593 3.322c1.1.128 1.907 1.077 1.907 2.185V21L12 17.25 4.5 21V5.507c0-1.108.806-2.057 1.907-2.185a48.507 48.507 0 0 1 11.186 0Z" />
        </svg>
        <span class="hor-resume-text"><a id="hor-resume-btn" href="#">Continue reading: <span id="hor-resume-title"></span></a></span>
        <button type="button" class="hor-resume-dismiss" aria-label="Dismiss">&#x2715;</button>
    </div>

    {# Section card grid — driven by helios_version_info #}
    {% if helios_version_info is defined and helios_version_info.versions|length > 0 %}
    {% set first_version = helios_version_info.versions|first %}
    {% set colClass = {
        1: 'grid-cols-1',
        2: 'sm:grid-cols-2',
        3: 'sm:grid-cols-2 lg:grid-cols-3'
    } %}
    {% set gridClasses = 'section-card-grid grid gap-4 mb-8 ' ~ (colClass[page.header.cards_per_row|default(1)] ?? 'grid-cols-1') ~ ' ' ~ (page.header.cards_per_row|default(1) == 2 ? 'section-card-grid--cols-2' : (page.header.cards_per_row|default(1) == 3 ? 'section-card-grid--cols-3' : '')) %}

    {% if has_parts %}
        {# Parts mode — render a labelled heading + card grid for each part #}
        {% for part_key, part_versions in part_groups %}
            {% if part_key != '__ungrouped__' %}
            <div class="hor-part-heading">
                <h2>{{ part_labels[part_key] ?? (part_key|replace({'-': ' '})|title) }}</h2>
            </div>
            {% endif %}
            <div class="{{ gridClasses }}">
                {% for version in part_versions %}
                    {% set card_page = pages.find('/' ~ version.id) %}
                    {% if card_page %}
                        {% set card_image = card_page.header.image ? card_page.media[card_page.header.image] : null %}
                        {% include 'partials/section-card.html.twig' with {
                            title: version.label,
                            link: card_page.url,
                            icon: card_page.header.icon|default(page.header.card_icon),
                            section_number: card_page.header.section_number|default(loop.index),
                            section_label: section_label,
                            description: card_page.header.description|default(null),
                            author: card_page.header.author|default(null),
                            badge_label: card_page.header.badge_label|default(null),
                            badge_color: card_page.header.badge_color|default('default'),
                            image: card_image,
                            image_layout: (page.header.cards_per_row|default(1) == 3) ? 'top' : page.header.card_image_layout|default('side'),
                            card_description_lines: page.header.card_description_lines|default(3)
                        } only %}
                    {% endif %}
                {% endfor %}
            </div>
        {% endfor %}
    {% else %}
        {# Flat mode — single grid for all sections (original behaviour) #}
        <div class="{{ gridClasses }}">
            {% for version in helios_version_info.versions %}
                {% set card_page = pages.find('/' ~ version.id) %}
                {% if card_page %}
                    {% set card_image = card_page.header.image ? card_page.media[card_page.header.image] : null %}
                    {% include 'partials/section-card.html.twig' with {
                        title: version.label,
                        link: card_page.url,
                        icon: card_page.header.icon|default(page.header.card_icon),
                        section_number: card_page.header.section_number|default(loop.index),
                        section_label: section_label,
                        description: card_page.header.description|default(null),
                        author: card_page.header.author|default(null),
                        badge_label: card_page.header.badge_label|default(null),
                        badge_color: card_page.header.badge_color|default('default'),
                        image: card_image,
                        image_layout: (page.header.cards_per_row|default(1) == 3) ? 'top' : page.header.card_image_layout|default('side'),
                        card_description_lines: page.header.card_description_lines|default(3)
                    } only %}
                {% endif %}
            {% endfor %}
        </div>
    {% endif %}

    {# Start Reading button — links directly to first section #}
    {% set btn_text = page.header.start_button_text ?? 'Start Reading' %}
    {% if btn_text %}
        {% set start_page = pages.find('/' ~ first_version.id) %}
        {% if start_page %}
        <div class="mb-8 no-print">
            <a href="{{ start_page.url }}" class="doc-btn doc-btn--primary">
                {{ btn_text }}
                <svg class="inline-block ml-2 w-4 h-4" aria-hidden="true" focusable="false" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
                </svg>
            </a>
        </div>
        {% endif %}
    {% endif %}
    {% endif %}

    {# Page content below section cards #}
    {% if content_below and content_below|trim %}
        <article class="prose prose-lg dark:prose-invert max-w-none mt-8">
            {{ content_below|raw }}
        </article>
    {% endif %}
{% endblock %}
